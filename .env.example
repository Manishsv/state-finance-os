# FinanceOS — environment configuration template
#
# Copy this file to `.env` (which is gitignored) and fill in your values.
# Loaded at CLI startup via python-dotenv. All variables are optional; FinanceOS
# falls back to sensible defaults when they are unset.

# ── LLM provider for the Advisor ─────────────────────────────────────────────
# Provider preset: anthropic | openai | ollama | groq | together | openrouter | lmstudio | custom
# FinanceOS defaults to `anthropic` (cloud Claude) — most users running budget
# analysis are on hosted APIs. Switch to `ollama` for local inference.
LLM_PROVIDER=anthropic

# Anthropic API key — required when LLM_PROVIDER=anthropic.
# Get one at https://console.anthropic.com/
# Either ANTHROPIC_API_KEY or LLM_API_KEY works for the anthropic provider.
ANTHROPIC_API_KEY=

# Universal API key fallback — used by OpenAI-compatible providers
# (openai, groq, together, openrouter). Ignored by ollama and lmstudio.
# LLM_API_KEY=

# Base URL for OpenAI-compatible providers — usually inferred from preset.
# Override only for self-hosted endpoints.
# LLM_BASE_URL=

# Model name. Defaults to the provider preset's default if unset.
# Anthropic:  claude-haiku-4-5 | claude-sonnet-4-6 | claude-opus-4-7
# OpenAI:     gpt-4o | gpt-4o-mini | gpt-4-turbo
# Ollama:     llama3.1 | qwen2.5 | gpt-oss:20b-cloud
# Groq:       llama-3.3-70b-versatile | mixtral-8x7b-32768
# OpenRouter: anthropic/claude-sonnet-4-6 | google/gemini-flash-1.5 | etc.
# LLM_MODEL=claude-sonnet-4-6

# Generation parameters
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1
LLM_TIMEOUT=120

# ── Knowledge Store ──────────────────────────────────────────────────────────
# Override the default SQLite path used by all CLI commands.
# FINANCEOS_DB_PATH=data/budgets/knowledge.sqlite

# ── Conformance gate bypass (test harnesses only) ───────────────────────────
# Per spec/CONFORMANCE.md §"Gate Bypass", this MUST default to false in any
# production environment. Setting it to true in production is non-conformant.
# FINANCEOS_SKIP_CONFORMANCE=false
